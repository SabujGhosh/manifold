{
  "name": "the-equations",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "description": "The Equations — 32 consequential equations explained at five levels of proficiency.",
  "scripts": {
    "predev": "pnpm run gen:meta",
    "dev": "vite",
    "gen:meta": "tsx scripts/generate-meta.ts",
    "validate": "tsx scripts/validate-content.ts",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "prebuild": "pnpm run validate && pnpm run gen:meta && pnpm run sitemap && tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "dompurify": "^3.1.6",
    "framer-motion": "^11.3.19",
    "katex": "^0.16.11",
    "marked": "^13.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/katex": "^0.16.7",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vitest": "^2.0.5"
  }
}
